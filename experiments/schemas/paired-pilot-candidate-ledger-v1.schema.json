{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "paired-pilot-candidate-ledger-v1.schema.json",
  "title": "Adaptive AI Orchestrator Phase 2b source candidate ledger",
  "description": "Result-blind source inventory used before task or evaluator construction.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "protocol_version",
    "ledger_id",
    "ledger_status",
    "created_at",
    "task_source_role_id",
    "agent_results_observed",
    "target_manifest_schema",
    "inclusion_rule_ids",
    "exclusion_rule_ids",
    "source_pools",
    "candidates",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "paired-pilot-candidate-ledger-v1"
    },
    "protocol_version": {
      "const": "phase2b-pilot-prereg-v1"
    },
    "ledger_id": {
      "$ref": "#/$defs/safeIdentifier"
    },
    "ledger_status": {
      "enum": ["screening", "frozen-for-task-construction"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "task_source_role_id": {
      "$ref": "#/$defs/safeIdentifier"
    },
    "agent_results_observed": {
      "const": false
    },
    "target_manifest_schema": {
      "const": "paired-pilot-manifest-v1"
    },
    "inclusion_rule_ids": {
      "const": [
        "license-or-use-basis",
        "exact-base-resolvable",
        "single-bounded-task",
        "native-language-source",
        "low-risk-isolated-execution",
        "no-network-secret-push-production",
        "objective-evaluator-feasible",
        "gold-and-evaluator-hideable",
        "reproducible-within-budget",
        "selection-independent-of-agent-results",
        "not-used-for-confirmatory-round"
      ]
    },
    "exclusion_rule_ids": {
      "const": [
        "no-parent-or-exact-base",
        "task-source-unavailable-or-underspecified",
        "translation-only",
        "multiple-coupled-issues",
        "unsafe-or-external-side-effect",
        "subjective-only-evaluation",
        "broken-or-flaky-fixture",
        "gold-or-evaluator-leakage",
        "resource-budget-exceeded",
        "selected-after-agent-result",
        "previous-paired-task-reuse"
      ]
    },
    "source_pools": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/sourcePool"
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "safeIdentifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "hash": {
      "type": "string",
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
    },
    "nullableHash": {
      "anyOf": [
        {"$ref": "#/$defs/hash"},
        {"type": "null"}
      ]
    },
    "screenState": {
      "enum": ["pass", "fail", "unknown"]
    },
    "sourcePool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_pool_id",
        "source_kind",
        "source_uri",
        "source_revision",
        "inventory_artifact_hash",
        "inventory_artifact_hash_basis",
        "license_or_use_basis",
        "inventory_method",
        "inventory_scope",
        "known_limitations"
      ],
      "properties": {
        "source_pool_id": {
          "$ref": "#/$defs/safeIdentifier"
        },
        "source_kind": {
          "enum": [
            "maintainer-history",
            "public-issue-dataset",
            "public-repository-issues",
            "synthetic-fixture-plan"
          ]
        },
        "source_uri": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source_revision": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "inventory_artifact_hash": {
          "$ref": "#/$defs/hash"
        },
        "inventory_artifact_hash_basis": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "license_or_use_basis": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "inventory_method": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "inventory_scope": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "known_limitations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "provisionalClassification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instruction_language",
        "task_category",
        "repository_code_language",
        "repository_doc_language"
      ],
      "properties": {
        "instruction_language": {
          "enum": ["ko", "en", "mixed", null]
        },
        "task_category": {
          "enum": [
            "implementation",
            "debugging",
            "testing",
            "refactoring",
            "repository-analysis-planning",
            null
          ]
        },
        "repository_code_language": {
          "enum": ["python", "javascript-typescript", "go", "java", "rust", "c-cpp", "other", null]
        },
        "repository_doc_language": {
          "enum": ["ko", "en", "mixed", "none", null]
        }
      }
    },
    "screening": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "license_or_use_basis",
        "exact_base_resolvable",
        "single_bounded_task",
        "native_language_source",
        "low_risk_isolated_execution",
        "no_network_secret_push_production",
        "objective_evaluator_feasible",
        "gold_and_evaluator_hideable",
        "reproducible_within_budget",
        "selection_independent_of_agent_results",
        "not_used_for_confirmatory_round"
      ],
      "properties": {
        "license_or_use_basis": {"$ref": "#/$defs/screenState"},
        "exact_base_resolvable": {"$ref": "#/$defs/screenState"},
        "single_bounded_task": {"$ref": "#/$defs/screenState"},
        "native_language_source": {"$ref": "#/$defs/screenState"},
        "low_risk_isolated_execution": {"$ref": "#/$defs/screenState"},
        "no_network_secret_push_production": {"$ref": "#/$defs/screenState"},
        "objective_evaluator_feasible": {"$ref": "#/$defs/screenState"},
        "gold_and_evaluator_hideable": {"$ref": "#/$defs/screenState"},
        "reproducible_within_budget": {"$ref": "#/$defs/screenState"},
        "selection_independent_of_agent_results": {"$ref": "#/$defs/screenState"},
        "not_used_for_confirmatory_round": {"$ref": "#/$defs/screenState"}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "source_pool_id",
        "source_cluster_id",
        "repository_id",
        "source_kind",
        "source_reference",
        "source_statement_available",
        "task_statement_hash",
        "base_revision",
        "base_tree_hash",
        "solution_reference",
        "solution_revision",
        "solution_artifact_hash",
        "solution_tree_hash",
        "source_evaluator_artifact_hash",
        "changed_files",
        "license_or_use_basis",
        "provisional_classification",
        "screening",
        "decision",
        "exclusion_rule_ids_triggered",
        "decision_reasons",
        "screened_by_role_id",
        "confirmatory_reuse_allowed"
      ],
      "properties": {
        "candidate_id": {
          "$ref": "#/$defs/safeIdentifier"
        },
        "source_pool_id": {
          "$ref": "#/$defs/safeIdentifier"
        },
        "source_cluster_id": {
          "$ref": "#/$defs/safeIdentifier"
        },
        "repository_id": {
          "$ref": "#/$defs/safeIdentifier"
        },
        "source_kind": {
          "enum": [
            "maintainer-history-delta",
            "public-issue-pr-pair",
            "benchmark-instance",
            "synthetic-fixture-proposal"
          ]
        },
        "source_reference": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source_statement_available": {
          "type": "boolean"
        },
        "task_statement_hash": {
          "$ref": "#/$defs/nullableHash"
        },
        "base_revision": {
          "$ref": "#/$defs/nullableHash"
        },
        "base_tree_hash": {
          "$ref": "#/$defs/nullableHash"
        },
        "solution_reference": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "solution_revision": {
          "$ref": "#/$defs/nullableHash"
        },
        "solution_artifact_hash": {
          "$ref": "#/$defs/hash"
        },
        "solution_tree_hash": {
          "$ref": "#/$defs/nullableHash"
        },
        "source_evaluator_artifact_hash": {
          "$ref": "#/$defs/nullableHash"
        },
        "changed_files": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "license_or_use_basis": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "provisional_classification": {
          "$ref": "#/$defs/provisionalClassification"
        },
        "screening": {
          "$ref": "#/$defs/screening"
        },
        "decision": {
          "enum": ["screening", "excluded", "selected-for-task-authoring"]
        },
        "exclusion_rule_ids_triggered": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "no-parent-or-exact-base",
              "task-source-unavailable-or-underspecified",
              "translation-only",
              "multiple-coupled-issues",
              "unsafe-or-external-side-effect",
              "subjective-only-evaluation",
              "broken-or-flaky-fixture",
              "gold-or-evaluator-leakage",
              "resource-budget-exceeded",
              "selected-after-agent-result",
              "previous-paired-task-reuse"
            ]
          }
        },
        "decision_reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "screened_by_role_id": {
          "$ref": "#/$defs/safeIdentifier"
        },
        "confirmatory_reuse_allowed": {
          "const": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"source_statement_available": {"const": true}},
            "required": ["source_statement_available"]
          },
          "then": {
            "properties": {
              "task_statement_hash": {"$ref": "#/$defs/hash"}
            }
          },
          "else": {
            "properties": {
              "task_statement_hash": {"type": "null"}
            }
          }
        },
        {
          "if": {
            "properties": {"decision": {"const": "excluded"}},
            "required": ["decision"]
          },
          "then": {
            "properties": {
              "exclusion_rule_ids_triggered": {"minItems": 1}
            }
          },
          "else": {
            "properties": {
              "exclusion_rule_ids_triggered": {"maxItems": 0}
            }
          }
        },
        {
          "if": {
            "properties": {"decision": {"const": "selected-for-task-authoring"}},
            "required": ["decision"]
          },
          "then": {
            "properties": {
              "source_statement_available": {"const": true},
              "task_statement_hash": {"$ref": "#/$defs/hash"},
              "base_revision": {"$ref": "#/$defs/hash"},
              "base_tree_hash": {"$ref": "#/$defs/hash"},
              "screening": {
                "properties": {
                  "license_or_use_basis": {"const": "pass"},
                  "exact_base_resolvable": {"const": "pass"},
                  "single_bounded_task": {"const": "pass"},
                  "native_language_source": {"const": "pass"},
                  "low_risk_isolated_execution": {"const": "pass"},
                  "no_network_secret_push_production": {"const": "pass"},
                  "objective_evaluator_feasible": {"const": "pass"},
                  "gold_and_evaluator_hideable": {"const": "pass"},
                  "reproducible_within_budget": {"const": "pass"},
                  "selection_independent_of_agent_results": {"const": "pass"},
                  "not_used_for_confirmatory_round": {"const": "pass"}
                }
              }
            }
          }
        }
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_count",
        "screening_count",
        "excluded_count",
        "selected_for_task_authoring_count",
        "language_assignment_counts",
        "category_assignment_counts",
        "known_gaps"
      ],
      "properties": {
        "candidate_count": {"type": "integer", "minimum": 0},
        "screening_count": {"type": "integer", "minimum": 0},
        "excluded_count": {"type": "integer", "minimum": 0},
        "selected_for_task_authoring_count": {"type": "integer", "minimum": 0},
        "language_assignment_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ko", "en", "mixed", "unassigned"],
          "properties": {
            "ko": {"type": "integer", "minimum": 0},
            "en": {"type": "integer", "minimum": 0},
            "mixed": {"type": "integer", "minimum": 0},
            "unassigned": {"type": "integer", "minimum": 0}
          }
        },
        "category_assignment_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "implementation",
            "debugging",
            "testing",
            "refactoring",
            "repository-analysis-planning",
            "unassigned"
          ],
          "properties": {
            "implementation": {"type": "integer", "minimum": 0},
            "debugging": {"type": "integer", "minimum": 0},
            "testing": {"type": "integer", "minimum": 0},
            "refactoring": {"type": "integer", "minimum": 0},
            "repository-analysis-planning": {"type": "integer", "minimum": 0},
            "unassigned": {"type": "integer", "minimum": 0}
          }
        },
        "known_gaps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    }
  }
}
